# ----------------------------
# GANTRY CONFIGURATION
# ----------------------------

# --- SECURITY & AUTH ---
# Shared secret required in the 'X-Token' HTTP header. Leave empty to disable token auth.
GANTRY_TOKEN=your-super-secret-token-here

# Optional IP allowlist (comma-separated). 
# If set, only these IPs can access the API. Leave empty to allow all.
GANTRY_IP_ALLOWLIST=127.0.0.1,192.168.1.50

# --- RATE LIMITING ---
# Global toggle for the in-memory rate limiter.
GANTRY_RATE_LIMIT_ENABLED=true

# List of IPs that ignore rate limits (comma-separated).
GANTRY_RATE_LIMIT_BYPASS_IPS=127.0.0.1

# --- SERVER SETUP ---
# The local port the API binds to.
GANTRY_PORT=8787

# The file path to your actions routing configuration.
GANTRY_ACTIONS_PATH=actions.json

# --- LOGGING ---
# Levels: DEBUG, INFO, WARNING, ERROR
GANTRY_LOG_LEVEL=INFO

# Path to log file. The /logs subfolder is created automatically.
GANTRY_LOG_FILE=logs/gantry.log

# Max size of a single log file (in bytes) before rotation (Default: 2MB).
GANTRY_LOG_MAX_BYTES=2097152

# Number of rotated log files to keep in history.
GANTRY_LOG_BACKUP_COUNT=5